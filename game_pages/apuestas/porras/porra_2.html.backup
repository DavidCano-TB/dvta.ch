                </div>
              `}
            </div>
            
            <!-- Número de Movimiento -->
            <div style="text-align:right;font-size:.65rem;color:var(--text3);">
              Movimiento #${sortedApuestas.length - index}
            </div>
          </div>
        `;
      });
      
      dvdHtml += `
            </div>
          </div>
          
          <!-- SECCIÓN 4: ANÁLISIS POR USUARIO -->
          <div style="background:var(--n4);border:2px solid var(--orange);border-radius:10px;padding:20px;">
            <div style="font-size:1.1rem;color:var(--orange);font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
              <span>👥</span> ANÁLISIS POR USUARIO
            </div>
            <div style="overflow-x:auto;">
              <table style="width:100%;border-collapse:collapse;">
                <thead>
                  <tr style="border-bottom:2px solid var(--border2);">
                    <th style="text-align:left;padding:12px;font-size:.75rem;color:var(--text3);background:var(--n3);">USUARIO</th>
                    <th style="text-align:center;padding:12px;font-size:.75rem;color:var(--text3);background:var(--n3);">APUESTAS</th>
                    <th style="text-align:right;padding:12px;font-size:.75rem;color:var(--text3);background:var(--n3);">TOTAL APOSTADO</th>
                    <th style="text-align:left;padding:12px;font-size:.75rem;color:var(--text3);background:var(--n3);">OPCIONES</th>
                  </tr>
                </thead>
                <tbody>
      `;
      
      // Agrupar apuestas por usuario
      const userStats = {};
      apuestas.forEach(a => {
        if(!userStats[a.username]){
          userStats[a.username] = {
            count: 0,
            total: 0,
            opciones: new Set()
          };
        }
        userStats[a.username].count++;
        userStats[a.username].total += a.cantidad;
        userStats[a.username].opciones.add(p.opciones.find(o => o.valor === a.opcion)?.nombre || a.opcion);
      });
      
      // Ordenar por total apostado
      const sortedUsers = Object.entries(userStats).sort((a,b) => b[1].total - a[1].total);
      
      sortedUsers.forEach(([username, stats], index) => {
        const bgColor = index % 2 === 0 ? 'var(--n3)' : 'transparent';
        dvdHtml += `
          <tr style="border-bottom:1px solid var(--border);background:${bgColor};">
            <td style="padding:12px;font-size:.85rem;color:var(--text);font-weight:700;">@${e(username)}</td>
            <td style="text-align:center;padding:12px;font-size:.8rem;color:var(--text2);">${stats.count}</td>
            <td style="text-align:right;padding:12px;font-size:.85rem;color:var(--gold2);font-weight:700;">${stats.total.toFixed(1)} DVDc</td>
            <td style="padding:12px;font-size:.75rem;color:var(--text3);">${Array.from(stats.opciones).join(', ')}</td>
          </tr>
        `;
      });
      
      dvdHtml += `
                </tbody>
              </table>
            </div>
          </div>
        </div>
      `;
      
      document.getElementById('dvdStatsPanel').innerHTML = dvdHtml;
      document.getElementById('dvdStatsPanel').style.display = '';
    } else {
      document.getElementById('dvdStatsPanel').style.display = 'none';
    }
    
// Update options stats
    for(let opt in stats.distribucion){
      const d=stats.distribucion[opt];
      const el=document.getElementById('stats_'+opt);
      if(el){
        // Calcular ganancia potencial por cada DVDc apostado
        const ganancia_por_dvdc=d.total>0?(stats.total_bote/d.total):0;
        const roi_potencial=d.total>0?((ganancia_por_dvdc-1)*100):0;
        
        el.innerHTML=`<div class="optStat"><span class="optStatLbl">Apostadores:</span><span class="optStatVal">${d.count}</span></div>
          <div class="optStat"><span class="optStatLbl">Total Apostado:</span><span class="optStatVal">${d.total.toFixed(1)} DVDc</span></div>
          <div class="optStat"><span class="optStatLbl">% del Bote:</span><span class="optStatVal">${d.porcentaje.toFixed(1)}%</span></div>
          <div class="optStat"><span class="optStatLbl">Cuota:</span><span class="optStatVal">${d.cuota_implicita>0?d.cuota_implicita.toFixed(2)+'x':'-'}</span></div>
          <div class="optStat"><span class="optStatLbl">Ganancia/DVDc:</span><span class="optStatVal">${ganancia_por_dvdc>0?ganancia_por_dvdc.toFixed(2)+' DVDc':'-'}</span></div>
          <div class="optStat"><span class="optStatLbl">ROI Potencial:</span><span class="optStatVal" style="color:${roi_potencial>=0?'var(--green)':'var(--red)'}">${roi_potencial>0?'+':''}${roi_potencial.toFixed(1)}%</span></div>`;
      }
      
      // Mark winner
      const card=document.querySelector(`[data-valor="${opt}"]`);
      if(card&&p.estado==='finalizada'&&p.resultado===opt){
        card.classList.add('winner');
      }
    }
  }catch(e){
    console.error('Error rendering porra:',e);
  }
}



// Función para traducir estados
function traducirEstado(estado){
  const traducciones = {
    'abierta': 'Abierta',
    'cerrada': 'Cerrada',
    'finalizada': 'Finalizada',
    'cancelada': 'Cancelada'
  };
  return traducciones[estado] || estado;
}

function selectOption(valor){
  console.log('🎯 Opción seleccionada:', valor);
  selectedOpt=valor;
  
  // Remover selección de todas las tarjetas
  document.querySelectorAll('.optCard').forEach(c=>{
    c.classList.remove('selected');
    c.style.border='3px solid rgba(212,168,67,.13)';
    c.style.background='var(--n3)';
    c.style.boxShadow='none';
    c.style.transform='none';
  });
  
  // Seleccionar la tarjeta clickeada
  const card=document.querySelector(`[data-valor="${valor}"]`);
  if(card){
    card.classList.add('selected');
    // Aplicar estilos inline para garantizar visibilidad
    card.style.border='5px solid #D4A843';
    card.style.background='rgba(212,168,67,.25)';
    card.style.boxShadow='0 0 40px rgba(212,168,67,.6)';
    card.style.transform='scale(1.05)';
    card.scrollIntoView({behavior:'smooth',block:'nearest'});
    console.log('✅ Tarjeta marcada como seleccionada');
    console.log('✅ Estilos inline aplicados');
  }else{
    console.error('❌ No se encontró la tarjeta con valor:', valor);
  }
  
  // Activar botón
  const btn=document.getElementById('betBtn');
  if(btn){
    btn.disabled=false;
    btn.style.opacity='1';
    btn.style.cursor='pointer';
    console.log('✅ Botón de apuesta activado');
  }
}

async function realizarApuesta(){
  const cantidad=parseFloat(document.getElementById('betAmount').value);
  if(!cantidad||cantidad<=0){alert('Introduce una cantidad válida');return;}
  if(cantidad<1){alert('La apuesta mínima es 1 DVDcoin');return;}
  if(cantidad>10000){alert('La apuesta máxima es 10000 DVDcoins');return;}
  if(!selectedOpt){alert('Selecciona una opción');return;}
  
  const optName=porraData.porra.opciones.find(o=>o.valor===selectedOpt)?.nombre;
  if(!confirm(`¿Apostar ${cantidad} DVDcoins a "${optName}"?`))return;
  
  const btn=document.getElementById('betBtn');
  btn.disabled=true;
  btn.textContent='Apostando...';
  
  console.log('🎲 Realizando apuesta:', {porra_id: PORRA_ID, opcion: selectedOpt, cantidad});
  
  try{
    const r=await fetch('/api/porras/apostar',{
      method:'POST',
      headers:{'Authorization':'Bearer '+tok,'Content-Type':'application/json','ngrok-skip-browser-warning':'1'},
      body:JSON.stringify({porra_id:PORRA_ID,opcion:selectedOpt,cantidad})
    });
    
    console.log('📡 Respuesta del servidor:', r.status, r.statusText);
    
    if(r.ok){
      const data=await r.json();
      console.log('✅ Apuesta exitosa:', data);
      showNotification('¡Apuesta registrada correctamente!','success');
      if(data.nuevo_balance!==undefined){
        showNotification(`Nuevo saldo: ${data.nuevo_balance.toFixed(1)} DVDc`,'info');
      }
      
      // Limpiar selección y campo para permitir nueva apuesta
      selectedOpt=null;
      document.getElementById('betAmount').value='';
      document.querySelectorAll('.optCard').forEach(c=>{
        c.classList.remove('selected');
        c.style.border='';
        c.style.background='';
        c.style.boxShadow='';
        c.style.transform='';
      });
      
      // Recargar datos
      setTimeout(()=>{
        loadData();
        // Reactivar botón después de recargar
        btn.disabled=false;
        btn.textContent='💸 Apostar Ahora';
      },500);
    }else{
      const contentType=r.headers.get('content-type');
      if(contentType&&contentType.includes('application/json')){
        const err=await r.json();
        console.error('❌ Error del servidor:', err);
        showNotification(err.detail||'Error al apostar','error');
      }else{
        const text=await r.text();
        console.error('❌ Respuesta no JSON:', text);
        showNotification('Error del servidor: '+r.status,'error');
      }
      btn.disabled=false;
      btn.textContent='💸 Apostar Ahora';
    }
  }catch(e){
    console.error('❌ Error de conexión:', e);
    showNotification('Error de conexión: '+e.message,'error');
    btn.disabled=false;
    btn.textContent='💸 Apostar Ahora';
  }
}

function showNotification(msg,type){
  const notif=document.createElement('div');
  notif.style.cssText=`position:fixed;top:80px;right:20px;z-index:1000;padding:16px 24px;border-radius:8px;font-size:.85rem;font-weight:600;box-shadow:0 4px 12px rgba(0,0,0,.3);animation:slideIn .3s ease;`;
  if(type==='success'){
    notif.style.background='rgba(56,184,122,.95)';
    notif.style.color='#fff';
    notif.textContent='✓ '+msg;
  }else if(type==='error'){
    notif.style.background='rgba(200,48,96,.95)';
    notif.style.color='#fff';
    notif.textContent='✗ '+msg;
  }else{
    notif.style.background='rgba(107,155,212,.95)';
    notif.style.color='#fff';
    notif.textContent='ℹ '+msg;
  }
  document.body.appendChild(notif);
  setTimeout(()=>{
    notif.style.animation='slideOut .3s ease';
    setTimeout(()=>notif.remove(),300);
  },3000);
}

init();
</script>
</body>
</html>
