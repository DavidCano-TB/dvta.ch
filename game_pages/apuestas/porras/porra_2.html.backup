<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,viewport-fit=cover">
<meta name="theme-color" content="#04040A">
<title>España VS Cabo verde</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--gold:#D4A843;--gold2:#F0C866;--gold3:#8B6010;--noir:#04040A;--n2:#08080F;--n3:#0C0C1A;--glass:rgba(255,255,255,.04);--border:rgba(212,168,67,.13);--border2:rgba(212,168,67,.30);--text:#EAE6D8;--text2:#9A9070;--text3:#504430;--green:#38B87A;--red:#C83060;--blue:#4878D8;--orange:#E07840;--r:12px;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-size:15px;}
body{background:var(--noir);color:var(--text);font-family:'DM Mono',monospace;min-height:100%;-webkit-font-smoothing:antialiased;padding-bottom:24px;}
button{-webkit-appearance:none;appearance:none;font-family:inherit;cursor:pointer;}
.hdr{position:sticky;top:0;z-index:50;background:rgba(4,4,10,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;padding:0 14px;height:52px;}
.hdr::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold3) 30%,var(--gold) 50%,var(--gold3) 70%,transparent);}
.hdrLogo{font-family:'Playfair Display',serif;font-size:.95rem;color:var(--gold2);flex:1;}
.wrap{max-width:1100px;margin:0 auto;padding:20px;}
.hero{background:linear-gradient(135deg,var(--n2),var(--n3));border:1px solid var(--border2);border-radius:var(--r);padding:32px;margin-bottom:24px;text-align:center;}
.heroTitle{font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--gold2);margin-bottom:16px;line-height:1.2;}
.heroDesc{font-size:.92rem;color:var(--text2);line-height:1.7;margin-bottom:20px;max-width:700px;margin-left:auto;margin-right:auto;}
.heroInfo{display:flex;gap:20px;justify-content:center;flex-wrap:wrap;font-size:.75rem;color:var(--text3);}
.heroInfo span{display:flex;align-items:center;gap:6px;background:rgba(212,168,67,.06);padding:6px 12px;border-radius:6px;}
.statsBar{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:28px;}
.statBox{background:var(--n3);border:1px solid var(--border);border-radius:var(--r);padding:20px;text-align:center;transition:all .3s;}
.statBox:hover{border-color:var(--gold);box-shadow:0 0 20px rgba(212,168,67,.1);}
.statVal{font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold2);margin-bottom:6px;}
.statLbl{font-size:.68rem;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;}
.badge{display:inline-block;padding:5px 12px;border-radius:6px;font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;}
.badge.abierta{background:rgba(56,184,122,.18);color:var(--green);border:1px solid rgba(56,184,122,.4);}
.badge.cerrada{background:rgba(72,120,216,.18);color:var(--blue);border:1px solid rgba(72,120,216,.4);}
.badge.finalizada{background:rgba(200,48,96,.18);color:var(--red);border:1px solid rgba(200,48,96,.4);}
.badge.cancelada{background:rgba(90,106,128,.18);color:var(--text3);border:1px solid rgba(90,106,128,.4);}
.section{background:var(--n2);border:1px solid var(--border2);border-radius:var(--r);padding:24px;margin-bottom:20px;}
.sectionTitle{font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--gold2);margin-bottom:18px;display:flex;align-items:center;gap:10px;}
.optionsGrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-bottom:24px;}
.optCard{background:var(--n3);border:3px solid var(--border);border-radius:var(--r);padding:22px;cursor:pointer !important;transition:all .3s;position:relative;overflow:hidden;user-select:none;}
.optCard::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--gold);transform:scaleX(0);transition:transform .3s;z-index:1;}
.optCard:hover{border-color:var(--gold);box-shadow:0 0 28px rgba(212,168,67,.2);transform:translateY(-3px);}
.optCard:hover::before{transform:scaleX(1);}
.optCard.selected{border:5px solid #D4A843 !important;background:rgba(212,168,67,.25) !important;box-shadow:0 0 40px rgba(212,168,67,.6) !important;transform:scale(1.05) !important;}
.optCard.selected::before{transform:scaleX(1) !important;background:#F0C866 !important;height:8px !important;}
.optCard.winner{border-color:var(--green);background:rgba(56,184,122,.12);box-shadow:0 0 32px rgba(56,184,122,.3);}
.optCard.winner::before{background:var(--green);transform:scaleX(1);}
.optIcon{width:70px;height:70px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2.2rem;margin:0 auto 14px;box-shadow:0 4px 12px rgba(0,0,0,.3);}
.optName{font-family:'Playfair Display',serif;font-size:1.25rem;color:var(--text);margin-bottom:14px;text-align:center;font-weight:700;}
.optStats{display:flex;flex-direction:column;gap:6px;font-size:.72rem;padding-top:12px;border-top:1px solid var(--border);}
.optStat{display:flex;justify-content:space-between;align-items:center;}
.optStatLbl{color:var(--text3);}
.optStatVal{color:var(--gold2);font-weight:600;}
.betPanel{background:linear-gradient(135deg,var(--n2),var(--n3));border:2px solid var(--border2);border-radius:var(--r);padding:28px;margin-bottom:24px;}
.betTitle{font-size:1.2rem;color:var(--gold2);margin-bottom:18px;text-align:center;}
.betInput{width:100%;background:rgba(212,168,67,.08);border:1px solid var(--border2);border-radius:var(--r);padding:14px;color:var(--text);font-family:'DM Mono',monospace;font-size:1.1rem;outline:none;margin-bottom:14px;text-align:center;}
.betInput:focus{border-color:var(--gold);background:rgba(212,168,67,.14);box-shadow:0 0 12px rgba(212,168,67,.2);}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;border:1px solid;border-radius:var(--r);padding:12px 20px;font-size:.85rem;font-family:'DM Mono',monospace;letter-spacing:.05em;transition:all .2s;cursor:pointer;font-weight:600;width:100%;}
.btnG{background:rgba(56,184,122,.15);border-color:rgba(56,184,122,.5);color:var(--green);}
.btnG:hover{background:rgba(56,184,122,.25);border-color:var(--green);box-shadow:0 0 16px rgba(56,184,122,.3);}
.btnG:disabled{opacity:.4;cursor:not-allowed;}
.btnO{background:rgba(212,168,67,.12);border-color:rgba(212,168,67,.4);color:var(--gold2);}
.btnO:hover{background:rgba(212,168,67,.22);box-shadow:0 0 16px rgba(212,168,67,.2);}
.btnD{background:rgba(200,48,96,.15);border-color:rgba(200,48,96,.4);color:#e05080;}
.btnD:hover{background:rgba(200,48,96,.25);}
.btnN{background:rgba(90,106,128,.15);border-color:rgba(90,106,128,.4);color:var(--text2);}
.btnN:hover{background:rgba(90,106,128,.25);border-color:rgba(90,106,128,.6);}
.apuestasList{margin-top:16px;}
.apuestaItem{background:var(--n3);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;transition:all .2s;}
.apuestaItem:hover{border-color:var(--gold);background:rgba(212,168,67,.05);}
.apuestaItem.ganador{border-color:var(--green);background:rgba(56,184,122,.08);}
.apuestaUser{font-size:.88rem;color:var(--text);font-weight:600;}
.apuestaOpt{font-size:.74rem;color:var(--text2);margin-top:3px;}
.apuestaCant{font-size:.95rem;color:var(--gold2);font-weight:700;}
.apuestaGanancia{font-size:.8rem;color:var(--green);margin-top:3px;}
.distBar{height:32px;background:var(--n4);border-radius:8px;overflow:hidden;display:flex;margin-bottom:12px;box-shadow:inset 0 2px 4px rgba(0,0,0,.3);}
.distSeg{display:flex;align-items:center;justify-content:center;font-size:.7rem;color:#fff;font-weight:700;transition:all .3s;cursor:pointer;}
.distSeg:hover{filter:brightness(1.2);}
.resultPanel{background:linear-gradient(135deg,rgba(56,184,122,.15),rgba(56,184,122,.08));border:2px solid var(--green);border-radius:var(--r);padding:28px;margin-bottom:24px;text-align:center;}
.resultTitle{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--green);margin-bottom:12px;}
.resultWinner{font-size:1.1rem;color:var(--text);margin-bottom:8px;}
.resultBote{font-family:'Playfair Display',serif;font-size:2.5rem;color:var(--gold2);margin:16px 0;}
.winnersList{background:var(--n3);border:1px solid var(--green);border-radius:var(--r);padding:20px;margin-top:16px;}
.winnerItem{display:flex;justify-content:space-between;padding:12px;background:rgba(56,184,122,.08);border-radius:8px;margin-bottom:8px;}
.empty{text-align:center;padding:40px 20px;color:var(--text3);font-size:.9rem;}
@keyframes slideIn{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
@keyframes slideOut{to{opacity:0;transform:translateX(100px)}}
</style>
</head>
<body>
<div class="hdr">
  <span style="font-size:1.3rem">🎲</span>
  <div class="hdrLogo">España VS Cabo verde</div>
  <span class="badge" id="estadoBadge">abierta</span>
</div>

<div class="wrap">
  <div class="hero">
    <div class="heroTitle">España VS Cabo verde</div>
    <div class="heroDesc">Primer Partido del mundial de fútbol 2026</div>
    <div class="heroInfo">
      <span>📅 Evento: <strong>15/06/2026 18:00</strong></span>
      <span>⏰ Cierre: <strong>15/06/2026 16:49</strong></span>
      <span>🎯 Tipo: <strong>marcador</strong></span>
    </div>
  </div>

  <!-- Estadísticas Generales de la Porra -->
  <div class="statsBar" id="statsGenerales">
    <div class="statBox">
      <div class="statVal" id="totalBote">0</div>
      <div class="statLbl">💰 Bote Total (DVDc)</div>
    </div>
    <div class="statBox">
      <div class="statVal" id="totalApostadores">0</div>
      <div class="statLbl">👥 Apostadores</div>
    </div>
    <div class="statBox">
      <div class="statVal" id="totalApuestas">0</div>
      <div class="statLbl">🎲 Total Apuestas</div>
    </div>
  </div>

  <!-- Estadísticas Personales de Esta Porra -->
  <div class="section" id="statsPersonalesPorra" style="display:none;">
    <div class="sectionTitle">📊 Tus Apuestas en Esta Porra</div>
    <div class="statsBar">
      <div class="statBox">
        <div class="statVal" id="tuApuesta">-</div>
        <div class="statLbl">🎯 Total Apostado</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="tuOpcion">-</div>
        <div class="statLbl">📌 Tus Opciones</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="tuPosibilidad">-</div>
        <div class="statLbl">📊 Probabilidad Promedio</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="tuGanancia">-</div>
        <div class="statLbl">🏆 Ganancia Total</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="tuROI">-</div>
        <div class="statLbl">💹 ROI Total</div>
      </div>
    </div>
  </div>

  <!-- Estadísticas Globales del Usuario -->
  <div class="section" id="statsGlobales" style="display:none;">
    <div class="sectionTitle">🏅 Tus Estadísticas Globales</div>
    <div class="statsBar">
      <div class="statBox">
        <div class="statVal" id="globalTotalPorras">0</div>
        <div class="statLbl">🎲 Total Porras</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalGanadas">0</div>
        <div class="statLbl">✅ Ganadas</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalPerdidas">0</div>
        <div class="statLbl">❌ Perdidas</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalWinRate">0%</div>
        <div class="statLbl">📈 Win Rate</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalApostado">0</div>
        <div class="statLbl">💸 Total Apostado</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalGanado">0</div>
        <div class="statLbl">💰 Total Ganado</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalBeneficio">0</div>
        <div class="statLbl">💵 Beneficio Neto</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalROI">0%</div>
        <div class="statLbl">📊 ROI Global</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalApuestaPromedio">0</div>
        <div class="statLbl">📏 Apuesta Promedio</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalGananciaPromedio">0</div>
        <div class="statLbl">🎯 Ganancia Promedio</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalMayorGanancia">0</div>
        <div class="statLbl">🏆 Mayor Ganancia</div>
      </div>
      <div class="statBox">
        <div class="statVal" id="globalRacha">-</div>
        <div class="statLbl">🔥 Racha Actual</div>
      </div>
    </div>
  </div>

  <div id="resultPanel" style="display:none;"></div>

  <!-- Panel de Estadísticas Completas - SOLO DVD -->
  <div id="dvdStatsPanel" style="display:none;"></div>


  <div class="section">
    <div class="sectionTitle">📊 Opciones de Apuesta</div>
    <div class="distBar" id="distBar"></div>
    <div class="optionsGrid" id="optionsGrid">
        <div class="optCard" data-valor="espaa_gana" onclick="selectOption('espaa_gana')">
          <div class="optIcon" style="background:#38B87A">🏈</div>
          <div class="optName">España gana</div>
          <div class="optStats" id="stats_espaa_gana">
            <div class="optStat"><span class="optStatLbl">Apostadores:</span><span class="optStatVal">0</span></div>
            <div class="optStat"><span class="optStatLbl">Total Apostado:</span><span class="optStatVal">0 DVDc</span></div>
            <div class="optStat"><span class="optStatLbl">% del Bote:</span><span class="optStatVal">0%</span></div>
            <div class="optStat"><span class="optStatLbl">Cuota:</span><span class="optStatVal">-</span></div>
            <div class="optStat"><span class="optStatLbl">Ganancia/DVDc:</span><span class="optStatVal">-</span></div>
            <div class="optStat"><span class="optStatLbl">ROI Potencial:</span><span class="optStatVal">-</span></div>
          </div>
        </div>
        <div class="optCard" data-valor="cabo_verde_gana" onclick="selectOption('cabo_verde_gana')">
          <div class="optIcon" style="background:#4878D8">🏐</div>
          <div class="optName">Cabo verde gana</div>
          <div class="optStats" id="stats_cabo_verde_gana">
            <div class="optStat"><span class="optStatLbl">Apostadores:</span><span class="optStatVal">0</span></div>
            <div class="optStat"><span class="optStatLbl">Total Apostado:</span><span class="optStatVal">0 DVDc</span></div>
            <div class="optStat"><span class="optStatLbl">% del Bote:</span><span class="optStatVal">0%</span></div>
            <div class="optStat"><span class="optStatLbl">Cuota:</span><span class="optStatVal">-</span></div>
            <div class="optStat"><span class="optStatLbl">Ganancia/DVDc:</span><span class="optStatVal">-</span></div>
            <div class="optStat"><span class="optStatLbl">ROI Potencial:</span><span class="optStatVal">-</span></div>
          </div>
        </div>
        <div class="optCard" data-valor="empate" onclick="selectOption('empate')">
          <div class="optIcon" style="background:#E07840">🌟</div>
          <div class="optName">Empate</div>
          <div class="optStats" id="stats_empate">
            <div class="optStat"><span class="optStatLbl">Apostadores:</span><span class="optStatVal">0</span></div>
            <div class="optStat"><span class="optStatLbl">Total Apostado:</span><span class="optStatVal">0 DVDc</span></div>
            <div class="optStat"><span class="optStatLbl">% del Bote:</span><span class="optStatVal">0%</span></div>
            <div class="optStat"><span class="optStatLbl">Cuota:</span><span class="optStatVal">-</span></div>
            <div class="optStat"><span class="optStatLbl">Ganancia/DVDc:</span><span class="optStatVal">-</span></div>
            <div class="optStat"><span class="optStatLbl">ROI Potencial:</span><span class="optStatVal">-</span></div>
          </div>
        </div></div>
  </div>

  <div id="betPanel" class="betPanel">
    <div class="betTitle">💰 Realizar Apuesta</div>
    <div style="margin-bottom:14px;font-size:.8rem;color:var(--text2);text-align:center;">
      Selecciona una opción arriba e introduce la cantidad a apostar.<br>
      <strong style="color:var(--gold2);">✨ Puedes apostar múltiples veces en diferentes opciones</strong>
    </div>
    <input type="number" class="betInput" id="betAmount" placeholder="Cantidad en DVDcoins" min="1" step="1">
    <button class="btn btnG" id="betBtn" onclick="realizarApuesta()" disabled>💸 Apostar Ahora</button>
  </div>
</div>

<script>
'use strict';
const PORRA_ID=2;
const e=s=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const ps=new URLSearchParams(location.search);
const tok=ps.get('token')||localStorage.getItem('dvd_token')||'';
let me=null,selectedOpt=null,porraData=null;

async function init(){
  if(!tok){alert('Sin sesión. Abre desde la aplicación.');return;}
  try{
    const r=await fetch('/api/me',{headers:{'Authorization':'Bearer '+tok,'ngrok-skip-browser-warning':'1'}});
    if(r.ok)me=await r.json();
  }catch(_){}
  
  // Load global stats
  if(me){
    try{
      const r=await fetch(`/api/porras/stats/${me.username}`,{headers:{'Authorization':'Bearer '+tok,'ngrok-skip-browser-warning':'1'}});
      if(r.ok){
        const stats=await r.json();
        updateGlobalStats(stats);
      }
    }catch(_){}
  }
  
  loadData();
  setInterval(loadData,10000);
}

function updateGlobalStats(stats){
  if(!stats||stats.total_porras===0){
    document.getElementById('statsGlobales').style.display='none';
    return;
  }
  
  document.getElementById('statsGlobales').style.display='';
  document.getElementById('globalTotalPorras').textContent=stats.total_porras;
  document.getElementById('globalGanadas').textContent=stats.porras_ganadas;
  document.getElementById('globalPerdidas').textContent=stats.porras_perdidas;
  document.getElementById('globalWinRate').textContent=stats.win_rate.toFixed(1)+'%';
  document.getElementById('globalApostado').textContent=stats.total_apostado.toFixed(1)+' DVDc';
  document.getElementById('globalGanado').textContent=stats.total_ganado.toFixed(1)+' DVDc';
  
  const beneficio=stats.beneficio_neto;
  const beneficioEl=document.getElementById('globalBeneficio');
  beneficioEl.textContent=(beneficio>=0?'+':'')+beneficio.toFixed(1)+' DVDc';
  beneficioEl.style.color=beneficio>=0?'var(--green)':'var(--red)';
  
  const roiEl=document.getElementById('globalROI');
  roiEl.textContent=(stats.roi>=0?'+':'')+stats.roi.toFixed(1)+'%';
  roiEl.style.color=stats.roi>=0?'var(--green)':'var(--red)';
  
  document.getElementById('globalApuestaPromedio').textContent=stats.apuesta_promedio.toFixed(1)+' DVDc';
  document.getElementById('globalGananciaPromedio').textContent=stats.ganancia_promedio.toFixed(1)+' DVDc';
  document.getElementById('globalMayorGanancia').textContent=stats.mayor_ganancia.toFixed(1)+' DVDc';
  
  if(stats.racha_actual>0){
    const rachaIcon=stats.racha_tipo==='ganadora'?'🔥':'❄️';
    document.getElementById('globalRacha').textContent=`${rachaIcon} ${stats.racha_actual} ${stats.racha_tipo}`;
  }else{
    document.getElementById('globalRacha').textContent='-';
  }
}

async function loadData(){
  try{
    const r=await fetch(`/api/porras/`+PORRA_ID,{headers:{'Authorization':'Bearer '+tok,'ngrok-skip-browser-warning':'1'}});
    if(!r.ok){
      const errorText=await r.text();
      console.error('Error loading porra:',errorText);
      document.body.innerHTML=`<div style="padding:40px;text-align:center;color:var(--text);">
        <h1 style="color:var(--red);">Error al cargar la porra</h1>
        <p>${errorText}</p>
        <button onclick="location.href='/apuestas?token=${tok}'" style="margin-top:20px;padding:10px 20px;background:var(--gold);border:none;border-radius:8px;cursor:pointer;">Volver a Apuestas</button>
      </div>`;
      return;
    }
    porraData=await r.json();
    render();
  }catch(e){
    console.error('Error loading data:',e);
    document.body.innerHTML=`<div style="padding:40px;text-align:center;color:var(--text);">
      <h1 style="color:var(--red);">Error de conexión</h1>
      <p>No se pudo cargar la porra. Por favor, intenta de nuevo.</p>
      <button onclick="location.reload()" style="margin-top:20px;padding:10px 20px;background:var(--gold);border:none;border-radius:8px;cursor:pointer;">Reintentar</button>
      <button onclick="location.href='/apuestas?token=${tok}'" style="margin-top:20px;margin-left:10px;padding:10px 20px;background:var(--n3);border:none;border-radius:8px;cursor:pointer;">Volver</button>
    </div>`;
  }
}

function render(){
  try{
    if(!porraData||!porraData.porra){
      console.error('No porra data available');
      return;
    }
    
    const p=porraData.porra;
    const stats=porraData.estadisticas;
    const apuestas=porraData.apuestas;
    
    if(!p||!stats||!apuestas){
      console.error('Incomplete porra data');
      return;
    }
  
    document.getElementById('estadoBadge').textContent=traducirEstado(p.estado);
    document.getElementById('estadoBadge').className='badge '+p.estado;
    
    document.getElementById('totalBote').textContent=stats.total_bote.toFixed(1);
    document.getElementById('totalApostadores').textContent=stats.total_apostadores;
    document.getElementById('totalApuestas').textContent=apuestas.length;
    
    const misApuestas=apuestas.filter(a=>a.username===me?.username);
    
    // Mostrar/ocultar secciones - AHORA permite múltiples apuestas
    if(misApuestas.length>0){
      // Mostrar estadísticas personales de esta porra (suma de todas sus apuestas)
      document.getElementById('statsPersonalesPorra').style.display='';
      
      // Calcular totales de todas las apuestas del usuario
      const totalApostado=misApuestas.reduce((sum,a)=>sum+a.cantidad,0);
      const totalGanado=misApuestas.reduce((sum,a)=>sum+(a.ganancia||0),0);
      
      // Mi apuesta total
      document.getElementById('tuApuesta').textContent=totalApostado.toFixed(1)+' DVDc';
      
      // Mis opciones (puede ser múltiple)
      const misOpciones=misApuestas.map(a=>p.opciones.find(o=>o.valor===a.opcion)?.nombre||a.opcion).join(', ');
      document.getElementById('tuOpcion').textContent=misOpciones;
      
      // Probabilidad promedio
      const probabilidades=misApuestas.map(a=>{
        const dist=stats.distribucion[a.opcion];
        return dist?dist.porcentaje:0;
      });
      const probPromedio=probabilidades.reduce((sum,p)=>sum+p,0)/probabilidades.length;
      document.getElementById('tuPosibilidad').textContent=probPromedio.toFixed(1)+'%';
      
      // Ganancia potencial o real
      if(p.estado==='finalizada'){
        if(totalGanado>0){
          // Ganó algo
          const gananciaEl=document.getElementById('tuGanancia');
          gananciaEl.textContent=totalGanado.toFixed(1)+' DVDc';
          gananciaEl.style.color='var(--green)';
          
          const roi=((totalGanado-totalApostado)/totalApostado*100);
          const roiEl=document.getElementById('tuROI');
          roiEl.textContent=(roi>=0?'+':'')+roi.toFixed(1)+'%';
          roiEl.style.color=roi>=0?'var(--green)':'var(--red)';
        }else{
          // Perdió todo
          const gananciaEl=document.getElementById('tuGanancia');
          gananciaEl.textContent='0 DVDc';
          gananciaEl.style.color='var(--red)';
          
          const roiEl=document.getElementById('tuROI');
          roiEl.textContent='-100%';
          roiEl.style.color='var(--red)';
        }
      }else{
        // Potencial (suma de todas las apuestas)
        let ganancia_potencial_total=0;
        misApuestas.forEach(a=>{
          const dist=stats.distribucion[a.opcion];
          if(dist&&dist.total>0){
            ganancia_potencial_total+=(stats.total_bote/dist.total)*a.cantidad;
          }
        });
        document.getElementById('tuGanancia').textContent=ganancia_potencial_total.toFixed(1)+' DVDc';
        const roi_potencial=((ganancia_potencial_total-totalApostado)/totalApostado*100);
        const roiEl=document.getElementById('tuROI');
        roiEl.textContent=(roi_potencial>=0?'+':'')+roi_potencial.toFixed(1)+'%';
        roiEl.style.color=roi_potencial>=0?'var(--green)':'var(--orange)';
      }
      
      // VALIDACIÓN CRÍTICA: Verificar si la deadline ha pasado

      
      // VERIFICAR DEADLINE EN TIEMPO REAL
    let porraCerrada = p.estado === 'cerrada' || p.estado === 'finalizada' || p.estado === 'cancelada';
    let mensajeCierre = '';
    
    // Si está "abierta", verificar si el deadline ya pasó
    if(p.estado === 'abierta' && p.fecha_limite){
      try{
        const ahora = new Date();
        const limite = new Date(p.fecha_limite);
        
        if(ahora >= limite){
          porraCerrada = true;
          mensajeCierre = 'La fecha límite ha pasado. Las apuestas están cerradas.';
          console.log('⏰ Deadline pasado, bloqueando apuestas');
        }
      }catch(e){
        console.error('Error verificando deadline:', e);
      }
    }
    
    // Determinar mensaje según estado
    if(!mensajeCierre){
      if(p.estado === 'cerrada'){
        mensajeCierre = 'Esperando resolución del resultado.';
      }else if(p.estado === 'finalizada'){
        mensajeCierre = 'La porra ha sido finalizada.';
      }else if(p.estado === 'cancelada'){
        mensajeCierre = 'La porra ha sido cancelada.';
      }
    }
    
    // Verificar si la porra está cerrada || p.estado === 'finalizada' || p.estado === 'cancelada';

      
      let mensajeCierre = '';

      
      

      
      // Verificar deadline SIEMPRE, incluso si el estado es "abierta"

      
      if(p.fecha_limite){

      
        try{

      
          const ahora = new Date();

      
          const limite = new Date(p.fecha_limite);

      
          

      
          if(ahora >= limite){

      
            porraCerrada = true;

      
            const fechaFormateada = limite.toLocaleString('es-ES', {

      
              day: '2-digit',

      
              month: '2-digit',

      
              year: 'numeric',

      
              hour: '2-digit',

      
              minute: '2-digit'

      
            });

      
            mensajeCierre = `La fecha límite (${fechaFormateada}) ha pasado.`;

      
            console.log('⏰ Deadline pasada:', fechaFormateada);

      
          }

      
        }catch(e){

      
          console.error('Error verificando deadline:', e);

      
        }

      
      }

      
      

      
      // Determinar mensaje según el estado

      
      if(!mensajeCierre){

      
        if(p.estado === 'cerrada'){

      
          mensajeCierre = 'Esperando resolución del resultado.';

      
        }else if(p.estado === 'finalizada'){

      
          mensajeCierre = 'La porra ha sido finalizada.';

      
        }else if(p.estado === 'cancelada'){

      
          mensajeCierre = 'La porra ha sido cancelada.';

      
        }

      
      }

      
      

      
      // Mostrar panel de apuestas solo si está abierta Y no ha pasado la deadline

      
      const betPanel = document.getElementById('betPanel');

      
      if(porraCerrada){

      
        // Mostrar mensaje claro: YA NO SE PUEDE APOSTAR MÁS

      
        betPanel.innerHTML = `

      
          <div class="betTitle" style="color:var(--red);">⏰ Ya no se puede apostar más</div>

      
          <div style="text-align:center;padding:20px;color:var(--text2);font-size:.9rem;">

      
            <p style="margin-bottom:10px;font-size:1rem;color:var(--text);">Esta porra ya no acepta apuestas.</p>

      
            <p style="color:var(--text3);font-size:.85rem;margin-top:12px;">

      
              ${mensajeCierre}

      
            </p>

      
          </div>

      
        `;

      
        betPanel.style.display = '';

      
      }else{

      
        // Panel de apuestas activo

      
        document.getElementById('betPanel').style.display = '';

      
      }
    }else{
      // No apostó: ocultar estadísticas personales de esta porra
      document.getElementById('statsPersonalesPorra').style.display='none';
      // Verificar si la porra está cerrada o finalizada
    const porraCerrada = p.estado === 'cerrada' || p.estado === 'finalizada' || p.estado === 'cancelada';
    
    // Mostrar panel de apuestas solo si está abierta
    const betPanel = document.getElementById('betPanel');
    if(porraCerrada){
      // Mostrar mensaje de porra cerrada
      betPanel.innerHTML = `
        <div class="betTitle">⏰ Apuestas Cerradas</div>
        <div style="text-align:center;padding:20px;color:var(--text2);font-size:.9rem;">
          <p style="margin-bottom:10px;">Esta porra ya no acepta más apuestas.</p>
          <p style="color:var(--text3);font-size:.8rem;">
            ${mensajeCierre}
          </p>
        </div>
      `;
      betPanel.style.display = '';
    }else{
      // Restaurar panel de apuestas original si está abierta
      betPanel.innerHTML = `
        <div class="betTitle">💰 Realizar Apuesta</div>
        <div style="margin-bottom:14px;font-size:.8rem;color:var(--text2);text-align:center;">
          Selecciona una opción arriba e introduce la cantidad a apostar.<br>
          <strong style="color:var(--gold2);">✨ Puedes apostar múltiples veces en diferentes opciones</strong>
        </div>
        <input type="number" class="betInput" id="betAmount" placeholder="Cantidad en DVDcoins" min="1" step="1">
        <button class="btn btnG" id="betBtn" onclick="realizarApuesta()" disabled>💸 Apostar Ahora</button>
      `;
      betPanel.style.display = '';
    }
    }
    
    // Result panel
    if(p.estado==='finalizada'&&p.resultado){
      const ganadores=apuestas.filter(a=>a.opcion===p.resultado);
      const optName=p.opciones.find(o=>o.valor===p.resultado)?.nombre||p.resultado;
      let html=`<div class="resultPanel">
        <div class="resultTitle">🏆 ¡Porra Finalizada!</div>
        <div class="resultWinner">Opción Ganadora: <strong>${e(optName)}</strong></div>
        <div class="resultBote">${stats.total_bote.toFixed(1)} DVDc</div>
        <div style="font-size:.85rem;color:var(--text2);">Repartidos entre ${ganadores.length} ganador${ganadores.length!==1?'es':''}</div>`;
      if(ganadores.length>0){
        html+=`<div class="winnersList"><div style="font-size:.9rem;color:var(--text2);margin-bottom:12px;font-weight:600;">💎 Ganadores:</div>`;
        ganadores.forEach(g=>{
          html+=`<div class="winnerItem">
            <span style="color:var(--text);font-weight:600;">@${e(g.username)}</span>
            <span style="color:var(--green);font-weight:700;">${g.ganancia.toFixed(1)} DVDc</span>
          </div>`;
        });
        html+=`</div>`;
      }
      html+=`</div>`;
      document.getElementById('resultPanel').innerHTML=html;
      document.getElementById('resultPanel').style.display='';
    }else{
      document.getElementById('resultPanel').style.display='none';
    }
    
    // Distribution bar
    const colors=['#38B87A','#4878D8','#E07840','#D4A843','#C83060','#6B9BD4','#E05260','#8BB3E8'];
    let barHtml='';
    let i=0;
    for(let opt in stats.distribucion){
      const d=stats.distribucion[opt];
      if(d.porcentaje>0){
        barHtml+=`<div class="distSeg" style="width:${d.porcentaje}%;background:${colors[i%colors.length]}" title="${e(d.nombre)}: ${d.porcentaje.toFixed(1)}%">${d.porcentaje>8?d.porcentaje.toFixed(0)+'%':''}</div>`;
        i++;
      }
    }
    document.getElementById('distBar').innerHTML=barHtml||'<div style="text-align:center;padding:8px;color:var(--text3);">Sin apuestas aún</div>';
    
        // Panel de Estadísticas Completas - SOLO DVD
    if(isDvd && apuestas.length > 0){
      let dvdHtml = `
